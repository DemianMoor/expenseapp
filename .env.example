SHEET_ID=15RqqqvqARGgv76FoGZK3emqpDTVOjmcQKuiI9PHgpAg

# --- Google auth ---
# LOCAL DEV: place oauth_client.json in the project root and run `npm run authorize`
#            (writes .google-token.json). No env vars needed.
#
# VERCEL / hosted: provide the OAuth client + refresh token as env vars:
#   GOOGLE_OAUTH_CLIENT_B64 = base64 of the whole oauth_client.json
#   GOOGLE_REFRESH_TOKEN    = the refresh_token from .google-token.json
# GOOGLE_OAUTH_CLIENT_B64=
# GOOGLE_REFRESH_TOKEN=
#
# (Alternative to _B64: GOOGLE_OAUTH_CLIENT_ID + GOOGLE_OAUTH_CLIENT_SECRET)
# (Legacy service-account path also still works: GOOGLE_SERVICE_ACCOUNT_B64)

# --- Access gate ---
# Set this in production to require a password before anyone can use the app.
# Leave UNSET locally to skip the login screen.
# APP_PASSWORD=choose-a-strong-password

# Optional: override the auto-detected subscriptions tab name (default: auto / "Subscriptions").
# SUBSCRIPTIONS_TAB=Payments
